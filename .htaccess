<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Bypass cards/ and news/ directories for bare paths (serve SPA directly)
  RewriteRule ^cards/?$ /index.html [L]
  RewriteRule ^news/?$ /index.html [L]

  # Serve existing files and directories directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Bot detection for news pages
  RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|Twitterbot|Discordbot|Slackbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Google.*snippet|bingbot|Googlebot|SkypeUriPreview|redditbot|Meta-ExternalAgent) [NC]
  RewriteRule ^news/([^/?#]+)/?$ /news/index.php?slug=$1 [L,QSA]

  # Pattern: /cards/{series}
  RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|Twitterbot|Discordbot|Slackbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Google.*snippet|bingbot|Googlebot|SkypeUriPreview|redditbot|Meta-ExternalAgent) [NC]
  RewriteRule ^cards/([^/]+)/?$ /cards/index.php [L,QSA]

  # Pattern: /cards/{series}/sets/{set}
  RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|Twitterbot|Discordbot|Slackbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Google.*snippet|bingbot|Googlebot|SkypeUriPreview|redditbot|Meta-ExternalAgent) [NC]
  RewriteRule ^cards/([^/]+)/sets/([^/]+)(?:/(?:pack-art|card-back))?/?$ /cards/index.php [L,QSA]

  # Pattern: /cards/{series}/sets/{set}/card/{sortBy_cardName}
  RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|Twitterbot|Discordbot|Slackbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Google.*snippet|bingbot|Googlebot|SkypeUriPreview|redditbot|Meta-ExternalAgent) [NC]
  RewriteRule ^cards/([^/]+)/sets/([^/]+)/card/([^/?#]+)/?$ /cards/index.php [L,QSA]

  RewriteRule . /index.html [L]
</IfModule>